generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(200)
  slug                String   @unique @db.VarChar(50)
  plan                String   @default("starter") @db.VarChar(20)
  wpp_provider        String   @default("meta_api") @db.VarChar(20)
  wpp_phone           String?  @db.VarChar(20)
  wpp_meta_phone_id   String?  @db.VarChar(100)
  wpp_meta_token      String?
  wpp_meta_app_secret String?
  welcome_message     String?
  active              Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz

  users               User[]
  products            Product[]
  employees           Employee[]
  tickets             Ticket[]
  orders              Order[]
  order_history       OrderHistory[]
  daily_closes        DailyClose[]
  revoked_form_tokens RevokedFormToken[]
  audit_logs          AuditLog[]

  @@map("organizations")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String    @db.Uuid
  email         String    @db.VarChar(200)
  password_hash String    @db.VarChar(100)
  name          String    @db.VarChar(200)
  role          String    @db.VarChar(20)
  active        Boolean   @default(true)
  last_login    DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz

  org            Organization   @relation(fields: [org_id], references: [id])
  refresh_tokens RefreshToken[]
  orders_registered Order[]     @relation("RegisteredBy")
  orders_paid       Order[]     @relation("PaidBy")
  history_entries   OrderHistory[]
  sent_messages     TicketMessage[]
  daily_closes      DailyClose[]
  revoked_form_tokens RevokedFormToken[]
  audit_logs          AuditLog[]

  @@unique([org_id, email])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @db.VarChar(100)
  expires_at DateTime @db.Timestamptz
  revoked    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([token_hash])
  @@index([user_id])
  @@map("refresh_tokens")
}

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id         String   @db.Uuid
  name           String   @db.VarChar(200)
  category       String?  @db.VarChar(100)
  active         Boolean  @default(true)
  sort_order     Int      @default(0)
  price_per_unit Decimal? @db.Decimal(12, 2)
  unit_type      String?  @db.VarChar(20)
  created_at     DateTime @default(now()) @db.Timestamptz

  org Organization @relation(fields: [org_id], references: [id])

  @@map("products")
}

model Employee {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id     String   @db.Uuid
  name       String   @db.VarChar(200)
  phone      String?  @db.VarChar(20)
  role       String   @default("domiciliario") @db.VarChar(20)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  org    Organization @relation(fields: [org_id], references: [id])
  orders Order[]

  @@map("employees")
}

model Ticket {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String    @db.Uuid
  phone           String    @db.VarChar(20)
  customer_name   String?   @db.VarChar(200)
  wpp_thread_id   String?   @db.VarChar(200)
  unread_count    Int       @default(0)
  last_message_at DateTime? @db.Timestamptz
  fecha           DateTime  @default(now()) @db.Date
  deferred_to     DateTime? @db.Date
  created_at      DateTime  @default(now()) @db.Timestamptz
  // Timestamp of the most recently issued form-link JWT for this ticket. Any token
  // whose own `iat` predates this is rejected as superseded — so sending a fresh
  // "Formulario" link automatically kills every earlier link for the same ticket,
  // with no separate "Bloquear link" click needed. Null = no link issued yet (or
  // issued before this field existed) — nothing to compare against, so old
  // already-issued tokens keep working until their own expiry.
  form_token_min_iat DateTime? @db.Timestamptz

  org      Organization    @relation(fields: [org_id], references: [id])
  messages TicketMessage[]
  orders   Order[]
  revoked_form_token RevokedFormToken?
  form_link_session  FormLinkSession?

  // One ticket per customer, forever — not per day. `fecha` still tracks the most
  // recent day this ticket was active (or is queued for, via `deferred_to`) so the
  // day-scoped board/informe queries keep working, but it's no longer part of the
  // ticket's identity: a customer writing again next week continues the same ticket
  // instead of forking a new one that the rest of the app (orders, staff replies)
  // has no way to find.
  @@unique([org_id, phone])
  @@index([org_id, fecha])
  @@index([org_id, deferred_to])
  @@index([org_id, last_message_at])
  @@map("tickets")
}

model TicketMessage {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id      String    @db.Uuid
  direction      String    @db.VarChar(5)
  text           String?
  media_url      String?   @db.VarChar(500)
  media_type     String?   @db.VarChar(50)
  media_caption  String?   @db.VarChar(500)
  sent_by        String?   @db.Uuid
  wpp_message_id String?   @unique @db.VarChar(200)
  sent_at        DateTime  @default(now()) @db.Timestamptz
  delivered      Boolean   @default(false)
  read_by_client Boolean   @default(false)

  ticket  Ticket @relation(fields: [ticket_id], references: [id])
  sender  User?  @relation(fields: [sent_by], references: [id])

  @@index([ticket_id, sent_at])
  @@map("ticket_messages")
}

model Order {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String    @db.Uuid
  ticket_id       String?   @db.Uuid
  num             String    @db.VarChar(10)
  customer_name   String    @db.VarChar(200)
  customer_phone  String?   @db.VarChar(20)
  address         String
  channel         String    @default("whatsapp") @db.VarChar(20)
  payment_method  String    @db.VarChar(20)
  status          String    @default("nuevo") @db.VarChar(20)
  employee_id     String?   @db.Uuid
  registered_by   String    @db.Uuid
  fecha           DateTime  @default(now()) @db.Date
  order_hour      DateTime  @default(now()) @db.Time
  paid            Boolean   @default(false)
  paid_at         DateTime? @db.Timestamptz
  paid_by         String?   @db.Uuid
  amount_received Decimal?  @db.Decimal(12, 2)
  change_amount   Decimal?  @db.Decimal(12, 2)
  locked          Boolean   @default(false)
  caja_cerrada    Boolean   @default(false)
  source          String    @default("encargado") @db.VarChar(20)
  notes           String?
  // Set whenever the CLIENT (not staff) adds/edits/removes items on this order via
  // the public form's merge flow — cleared when staff saves the order (routes/orders.ts
  // PATCH /:id), which is treated as "staff reviewed the change". Independent of any
  // individual item's own `added_by_client` flag below, which never clears — this is
  // a transient "needs attention" signal, that's permanent provenance.
  client_modified Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  org          Organization   @relation(fields: [org_id], references: [id])
  ticket       Ticket?        @relation(fields: [ticket_id], references: [id])
  employee     Employee?      @relation(fields: [employee_id], references: [id])
  registeredBy User           @relation("RegisteredBy", fields: [registered_by], references: [id])
  paidBy       User?          @relation("PaidBy", fields: [paid_by], references: [id])
  items        OrderItem[]
  history      OrderHistory[]

  @@unique([org_id, num, fecha])
  @@index([org_id, fecha])
  @@index([ticket_id])
  @@index([org_id, status])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id       String   @db.Uuid
  product_name   String   @db.VarChar(200)
  quantity_label String?  @db.VarChar(100)
  price          Decimal  @default(0) @db.Decimal(12, 2)
  sort_order     Int      @default(0)
  quantity_value Decimal? @db.Decimal(10, 3)
  quantity_unit  String?  @db.VarChar(20)
  // True if a client (via the public form's merge flow) added this line or changed
  // its quantity — never reset back to false afterward, even once staff has dealt
  // with it, so the item's origin stays visible in the UI (rendered in red) for as
  // long as the order exists. Items from the original submission or staff's own
  // entry stay false forever.
  added_by_client Boolean  @default(false)

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@map("order_items")
}

model OrderHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id       String   @db.Uuid
  order_id     String   @db.Uuid
  actor_id     String   @db.Uuid
  action_type  String   @db.VarChar(20)
  field        String?  @db.VarChar(100)
  value_before String?
  value_after  String?
  notes        String?
  created_at   DateTime @default(now()) @db.Timestamptz

  org   Organization @relation(fields: [org_id], references: [id])
  order Order        @relation(fields: [order_id], references: [id])
  actor User         @relation(fields: [actor_id], references: [id])

  @@index([order_id])
  @@index([org_id, created_at])
  @@map("order_history")
}

model DailyClose {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id         String   @db.Uuid
  fecha          DateTime @db.Date
  total_cash     Decimal  @default(0) @db.Decimal(12, 2)
  total_transfer Decimal  @default(0) @db.Decimal(12, 2)
  total_grand    Decimal  @default(0) @db.Decimal(12, 2)
  total_orders   Int      @default(0)
  closed_orders  Int      @default(0)
  decisions      Json?
  report_url     String?  @db.VarChar(500)
  closed_by      String   @db.Uuid
  closed_at      DateTime @default(now()) @db.Timestamptz

  org      Organization @relation(fields: [org_id], references: [id])
  closedBy User         @relation(fields: [closed_by], references: [id])

  @@unique([org_id, fecha])
  @@map("daily_closes")
}

// One row per ticket at most — revoking early-invalidates that ticket's currently
// outstanding form-link token (public.ts checks this before form-info/products/submit).
// Generating a fresh link afterwards works normally: it's a new JWT, this row just
// blocks whichever token was already issued when revoke was clicked.
model RevokedFormToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id     String   @db.Uuid
  ticket_id  String   @unique @db.Uuid
  reason     String?  @db.VarChar(255)
  revoked_at DateTime @default(now()) @db.Timestamptz
  revoked_by String   @db.Uuid

  org       Organization @relation(fields: [org_id], references: [id])
  ticket    Ticket       @relation(fields: [ticket_id], references: [id])
  revokedBy User         @relation(fields: [revoked_by], references: [id])

  @@index([org_id])
  @@map("revoked_form_tokens")
}

// Claims a ticket's form-link for whichever browser/device opens it FIRST — there's
// no real "device identity" reachable from a web page, so `device_token` is just a
// random value the client generates once and persists in its own localStorage
// (public.ts's routes below). First request for a ticket with no row yet claims it;
// any later request presenting a DIFFERENT device_token is rejected as if the link
// were invalid, same as an expired/revoked one (never reveals *why* it failed).
// Cleared whenever staff issues a fresh link for this ticket (inbox.ts) — that's a
// deliberate "start over" action, e.g. after a false-positive lockout.
model FormLinkSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id    String   @unique @db.Uuid
  device_token String   @db.VarChar(100)
  claimed_at   DateTime @default(now()) @db.Timestamptz

  ticket Ticket @relation(fields: [ticket_id], references: [id])

  @@map("form_link_sessions")
}

// Trail for security-sensitive account/config actions (user create, password reset,
// role/active change, WPP credential update) — none of these were logged anywhere
// before, unlike Order which already has OrderHistory. Write-only from the app's
// perspective; read via the /dev DB viewer (dev role only).
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id     String   @db.Uuid
  actor_id   String   @db.Uuid
  action     String   @db.VarChar(50)
  target_id  String?  @db.Uuid
  metadata   Json?
  created_at DateTime @default(now()) @db.Timestamptz

  org   Organization @relation(fields: [org_id], references: [id])
  actor User         @relation(fields: [actor_id], references: [id])

  @@index([org_id, created_at])
  @@map("audit_logs")
}
