generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(200)
  slug                String   @unique @db.VarChar(50)
  plan                String   @default("starter") @db.VarChar(20)
  wpp_provider        String   @default("meta_api") @db.VarChar(20)
  wpp_phone           String?  @db.VarChar(20)
  wpp_meta_phone_id   String?  @db.VarChar(100)
  wpp_meta_token      String?
  wpp_meta_app_secret String?
  active              Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz

  users         User[]
  products      Product[]
  employees     Employee[]
  tickets       Ticket[]
  orders        Order[]
  order_history OrderHistory[]
  daily_closes  DailyClose[]

  @@map("organizations")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String    @db.Uuid
  email         String    @db.VarChar(200)
  password_hash String    @db.VarChar(100)
  name          String    @db.VarChar(200)
  role          String    @db.VarChar(20)
  active        Boolean   @default(true)
  last_login    DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz

  org            Organization   @relation(fields: [org_id], references: [id])
  refresh_tokens RefreshToken[]
  orders_registered Order[]     @relation("RegisteredBy")
  orders_paid       Order[]     @relation("PaidBy")
  history_entries   OrderHistory[]
  sent_messages     TicketMessage[]
  daily_closes      DailyClose[]

  @@unique([org_id, email])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @db.VarChar(100)
  expires_at DateTime @db.Timestamptz
  revoked    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id         String   @db.Uuid
  name           String   @db.VarChar(200)
  category       String?  @db.VarChar(100)
  active         Boolean  @default(true)
  sort_order     Int      @default(0)
  price_per_unit Decimal? @db.Decimal(12, 2)
  unit_type      String?  @db.VarChar(20)
  created_at     DateTime @default(now()) @db.Timestamptz

  org Organization @relation(fields: [org_id], references: [id])

  @@map("products")
}

model Employee {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id     String   @db.Uuid
  name       String   @db.VarChar(200)
  phone      String?  @db.VarChar(20)
  role       String   @default("domiciliario") @db.VarChar(20)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  org    Organization @relation(fields: [org_id], references: [id])
  orders Order[]

  @@map("employees")
}

model Ticket {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String    @db.Uuid
  phone           String    @db.VarChar(20)
  customer_name   String?   @db.VarChar(200)
  wpp_thread_id   String?   @db.VarChar(200)
  unread_count    Int       @default(0)
  last_message_at DateTime? @db.Timestamptz
  fecha           DateTime  @default(now()) @db.Date
  deferred_to     DateTime? @db.Date
  created_at      DateTime  @default(now()) @db.Timestamptz

  org      Organization    @relation(fields: [org_id], references: [id])
  messages TicketMessage[]
  orders   Order[]

  @@unique([org_id, phone, fecha])
  @@map("tickets")
}

model TicketMessage {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id      String    @db.Uuid
  direction      String    @db.VarChar(5)
  text           String?
  media_url      String?   @db.VarChar(500)
  media_type     String?   @db.VarChar(50)
  media_caption  String?   @db.VarChar(500)
  sent_by        String?   @db.Uuid
  wpp_message_id String?   @unique @db.VarChar(200)
  sent_at        DateTime  @default(now()) @db.Timestamptz
  delivered      Boolean   @default(false)
  read_by_client Boolean   @default(false)

  ticket  Ticket @relation(fields: [ticket_id], references: [id])
  sender  User?  @relation(fields: [sent_by], references: [id])

  @@map("ticket_messages")
}

model Order {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String    @db.Uuid
  ticket_id       String?   @db.Uuid
  num             String    @db.VarChar(10)
  customer_name   String    @db.VarChar(200)
  customer_phone  String?   @db.VarChar(20)
  address         String
  channel         String    @default("whatsapp") @db.VarChar(20)
  payment_method  String    @db.VarChar(20)
  status          String    @default("nuevo") @db.VarChar(20)
  employee_id     String?   @db.Uuid
  registered_by   String    @db.Uuid
  fecha           DateTime  @default(now()) @db.Date
  order_hour      DateTime  @default(now()) @db.Time
  paid            Boolean   @default(false)
  paid_at         DateTime? @db.Timestamptz
  paid_by         String?   @db.Uuid
  amount_received Decimal?  @db.Decimal(12, 2)
  change_amount   Decimal?  @db.Decimal(12, 2)
  locked          Boolean   @default(false)
  caja_cerrada    Boolean   @default(false)
  notes           String?
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  org          Organization   @relation(fields: [org_id], references: [id])
  ticket       Ticket?        @relation(fields: [ticket_id], references: [id])
  employee     Employee?      @relation(fields: [employee_id], references: [id])
  registeredBy User           @relation("RegisteredBy", fields: [registered_by], references: [id])
  paidBy       User?          @relation("PaidBy", fields: [paid_by], references: [id])
  items        OrderItem[]
  history      OrderHistory[]

  @@unique([org_id, num, fecha])
  @@map("orders")
}

model OrderItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id       String   @db.Uuid
  product_name   String   @db.VarChar(200)
  quantity_label String?  @db.VarChar(100)
  price          Decimal  @default(0) @db.Decimal(12, 2)
  sort_order     Int      @default(0)
  quantity_value Decimal? @db.Decimal(10, 3)
  quantity_unit  String?  @db.VarChar(20)

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderHistory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id       String   @db.Uuid
  order_id     String   @db.Uuid
  actor_id     String   @db.Uuid
  action_type  String   @db.VarChar(20)
  field        String?  @db.VarChar(100)
  value_before String?
  value_after  String?
  notes        String?
  created_at   DateTime @default(now()) @db.Timestamptz

  org   Organization @relation(fields: [org_id], references: [id])
  order Order        @relation(fields: [order_id], references: [id])
  actor User         @relation(fields: [actor_id], references: [id])

  @@map("order_history")
}

model OrderTrash {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id     String   @db.Uuid
  order_id   String   @db.Uuid
  deleted_by String   @db.Uuid
  reason     String?
  deleted_at DateTime @default(now()) @db.Timestamptz

  @@map("order_trash")
}

model DailyClose {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id         String   @db.Uuid
  fecha          DateTime @db.Date
  total_cash     Decimal  @default(0) @db.Decimal(12, 2)
  total_transfer Decimal  @default(0) @db.Decimal(12, 2)
  total_grand    Decimal  @default(0) @db.Decimal(12, 2)
  total_orders   Int      @default(0)
  closed_orders  Int      @default(0)
  decisions      Json?
  report_url     String?  @db.VarChar(500)
  closed_by      String   @db.Uuid
  closed_at      DateTime @default(now()) @db.Timestamptz

  org      Organization @relation(fields: [org_id], references: [id])
  closedBy User         @relation(fields: [closed_by], references: [id])

  @@unique([org_id, fecha])
  @@map("daily_closes")
}
