# ============================================================
# 4CLIENT API — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ============================================================

# --- Base de datos (Railway PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# --- Auth ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambiar_por_64_bytes_aleatorios_hex"
JWT_REFRESH_SECRET="cambiar_por_otro_64_bytes_aleatorios_hex"

# --- Entorno ---
NODE_ENV="production"
PORT=3000

# --- Frontend URL (para CORS) ---
# En producción: tu dominio de Vercel o personalizado
FRONTEND_URL="https://app.tudominio.com"

# --- Meta / WhatsApp Business API ---
# Obtener desde developers.facebook.com una vez aprobado por el cliente
META_WEBHOOK_VERIFY_TOKEN="token_secreto_que_tu_defines"
META_PHONE_NUMBER_ID="id_del_numero_en_meta"
META_ACCESS_TOKEN="token_de_sistema_permanente_meta"
META_APP_SECRET="app_secret_del_app_meta"
# Obligatorio en producción — el server no arranca sin este valor (evita que el
# webhook acepte mensajes falsos sin firma HMAC verificada).

# --- Cifrado de credenciales WhatsApp en base de datos (opcional pero recomendado) ---
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si no se define, wpp_meta_token se guarda en texto plano (comportamiento legacy).
WPP_TOKEN_ENC_KEY="64_hex_chars_de_32_bytes_aleatorios"

# --- Cloudflare R2 (almacenamiento de PDFs) ---
# Crear bucket en dash.cloudflare.com → R2 → Create bucket
# Crear API token con permisos R2:Read, R2:Write en R2 → Manage API Tokens
R2_ACCOUNT_ID="tu_account_id_de_cloudflare"
R2_ACCESS_KEY_ID="tu_r2_access_key_id"
R2_SECRET_ACCESS_KEY="tu_r2_secret_access_key"
R2_BUCKET_NAME="4client-files"
# URL pública del bucket (si habilitas acceso público o dominio personalizado)
# Si no: las facturas se sirven a través de la API (descarga autenticada)
R2_PUBLIC_URL="https://files.yourdomain.r2.dev"
